# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored — never commit real keys.

# Found in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only used in server-side edge functions / cron jobs, never in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# A random string you make up — used to verify that cron requests to
# /api/cron/retention-purge actually came from Vercel, not a random visitor.
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# Optional — only needed once you wire up AI question generation
LLM_API_KEY=
